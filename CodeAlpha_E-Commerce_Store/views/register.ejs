<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="form-box">

    <h1>Create Account</h1>

    <form method="POST">

        <input
        type="text"
        name="name"
        placeholder="Full Name"
        required>

        <input
        type="email"
        name="email"
        placeholder="Email"
        required>

        <input
        type="password"
        name="password"
        placeholder="Password"
        required>

        <button>Register</button>

    </form>

</div>

</body>
</html>